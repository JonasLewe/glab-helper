echo ""
hr
echo "  ${MAGENTA}${ICON_USER}${RESET} ${BOLD}Assignee${RESET} ${DIM}(ENTER=confirm, ESC=abort)${RESET}"
echo ""

assignee=""
if [[ -n "$members" ]]; then
  member_options="  Skip (no assignee)
${ICON_NEW} Enter manually...
${members}"

  selected_member=$(fzf \
