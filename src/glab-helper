  milestones=$(jq -r '.[].title // empty' <<< "$ms_json" 2>/dev/null)
else
  milestones=""
fi
ms_count=$(awk 'NF{c++} END{print c+0}' <<< "$milestones")

printf "\r                                    \r"

# Show stats
echo "  ${DIM}${label_count} labels  ·  ${member_count} members  ·  ${ms_count} milestones${RESET}"
echo ""

# ═══════════════════════════════════════════
