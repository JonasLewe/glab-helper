#!/usr/bin/env zsh
# ─────────────────────────────────────────────────────────────
# glab-helper — Interactive GitLab workflow helper
# ─────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Install dependencies:
#        brew install glab fzf jq
#
#   2. Authenticate glab:
#        glab auth login
#      → Choose your GitLab instance URL
#      → Auth method: Token
#      → Create token at: Settings → Access Tokens
#        (Scopes: api, read_repository, write_repository)
#      → Protocol: HTTPS (or SSH if configured)
#
#   3. Verify:
#        glab auth status
#
#   4. Run from any GitLab repo:
#        glab-helper
#
# DEPENDENCIES: glab, fzf (0.35+), jq, curl, nvim (optional, falls back to vim)
# ─────────────────────────────────────────────────────────────

# ─── Help flag ───
TESTING=false
if [[ "$1" == "--test" || "$1" == "-t" ]]; then
  TESTING=true
  shift
fi

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo ""
  echo "  glab-helper — Interactive GitLab workflow helper"
  echo ""
  echo "  Usage: glab-helper [--test]"
  echo ""
  echo "  Options:"
  echo "    --test, -t  Skip Jira target project check (for testing)"
  echo ""
  echo "  Run from any cloned GitLab repo. Requires: glab, fzf, jq"
  echo "  Authenticate first: glab auth login"
  echo ""
  exit 0
fi

# ─── Colors & Symbols ───
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'
CYAN=$'\033[36m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
RED=$'\033[31m'
MAGENTA=$'\033[35m'

ICON_OK="✔"
ICON_WARN="!"
ICON_TITLE="▸"
ICON_LABEL="◆"
ICON_USER="◉"
ICON_MILE="▷"
ICON_DESC="¶"
ICON_NEW="+"
ICON_BRANCH="⎇"
ICON_SYNC="~"

BOX="${CYAN}${BOLD}"
BOX_V="${BOX}│${RESET}"

hr() { echo "  ${DIM}──────────────────────────────────────────────${RESET}"; }

# ─── Dependency check ───
missing=()
for cmd in glab fzf jq curl; do
  if ! command -v "$cmd" &>/dev/null; then
    missing+=("$cmd")
  fi
done
if [[ ${#missing[@]} -gt 0 ]]; then
  echo ""
  echo "  ${RED}${ICON_WARN} Missing dependencies:${RESET} ${missing[*]}"
  echo ""
  echo "  Install with:"
  if [[ "$(uname)" == "Darwin" ]]; then
    echo "    ${DIM}brew install ${missing[*]}${RESET}"
  else
    echo "    ${DIM}sudo pacman -S ${missing[*]}${RESET}"
  fi
  echo ""
  echo "  Then authenticate glab:"
  echo "    ${DIM}glab auth login${RESET}"
  echo ""
  exit 1
fi

# ─── Temp file cleanup ───
_tmpfiles=()
cleanup_tmpfiles() { for f in "${_tmpfiles[@]}"; do rm -f "$f" 2>/dev/null; done; }
trap 'cleanup_tmpfiles' EXIT INT TERM

# ─── Clear screen ───
clear

# ─── Repo info ───
echo ""
echo -n "  ${DIM}Connecting to GitLab...${RESET}"

repo_info=$(glab repo view --output json 2>/dev/null) || {
  printf "\r                                \r"
  echo ""
  echo "  ${RED}${ICON_WARN} Not in a GitLab repo or not authenticated.${RESET}"
  echo ""
  echo "  Make sure you:"
  echo "    1. ${DIM}cd${RESET} into a cloned GitLab repo"
  echo "    2. Run ${DIM}glab auth login${RESET} if not yet authenticated"
  echo "    3. Run ${DIM}glab auth status${RESET} to verify"
  echo ""
  exit 1
}

repo_name=$(jq -r '.path_with_namespace // .name_with_namespace // .name // "unknown"' <<< "$repo_info")
project_id=$(jq -r '.id' <<< "$repo_info")

printf "\r                                \r"

# ─── Dynamic header box width ───
if [[ ${#repo_name} -gt 80 ]]; then
  repo_name="${repo_name:0:77}..."
fi
BOX_WIDTH=$(( ${#repo_name} > 40 ? ${#repo_name} + 8 : 48 ))

box_line() {
  local text="$1"
  local visible_len=${#text}
  local pad=$((BOX_WIDTH - visible_len - 2))
  if [[ $pad -lt 0 ]]; then pad=0; fi
  local spaces=""
  if [[ $pad -gt 0 ]]; then
    spaces=$(printf '%*s' "$pad" '')
  fi
  echo "  ${BOX}║${RESET}  ${text}${spaces}${BOX}║${RESET}"
}

# ─── Header ───
box_top="$(printf '═%.0s' $(seq 1 $BOX_WIDTH))"

echo ""
echo "  ${BOX}╔${box_top}╗${RESET}"
box_line "GitLab Helper"
box_line "${repo_name}"
echo "  ${BOX}╚${box_top}╝${RESET}"
echo ""

# ─── Shared helpers ───

# Validate JSON response, return fallback if invalid (e.g. HTML error pages)
safe_json() {
  local response="$1" fallback="${2:-[]}"
  if jq -e . <<< "$response" &>/dev/null; then
    echo "$response"
  else
    echo "$fallback"
  fi
}

slugify() {
  local result
  result=$(echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/--*/-/g' \
    | sed 's/^-//;s/-$//')
  # Fallback for non-ASCII-only titles
  if [[ -z "$result" ]]; then
    result="issue"
  fi
  echo "$result"
}

get_default_branch() {
  local branch
  branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  if [[ -z "$branch" ]]; then
    branch=$(glab api "projects/$project_id" 2>/dev/null | jq -r '.default_branch // "main"')
  fi
  echo "$branch"
}

# Fetch all active milestones with pagination
fetch_all_milestones() {
  local page=1 per_page=100 all="[]"
  while true; do
    local page_json
    page_json=$(safe_json "$(glab api "projects/$project_id/milestones?state=active&per_page=${per_page}&page=${page}" 2>/dev/null)" "[]")
    local count
    count=$(jq 'length' <<< "$page_json")
    all=$(jq -s '.[0] + .[1]' <<< "${all}"$'\n'"${page_json}")
    [[ "$count" -lt "$per_page" ]] && break
    ((page++))
  done
  echo "$all"
}

# Retry a command up to N times with 1s delay between attempts
retry() {
  local max_attempts="${1:-3}"
  shift
  local attempt=1
  while (( attempt <= max_attempts )); do
    if "$@" 2>/dev/null; then
      return 0
    fi
    ((attempt++))
    [[ $attempt -le $max_attempts ]] && sleep 1
  done
  return 1
}

# Create a branch from default branch and optionally check it out
# Usage: offer_branch_creation <issue_number> <title>
offer_branch_creation() {
  local issue_nr="$1"
  local issue_title="$2"
  local slug branch_name branch_name_input want_branch
  local do_checkout checkout_err checkout_rc branch_err
  local default_branch branch_list selected_base

  slug=$(slugify "$issue_title")
  branch_name="${issue_nr}-${slug}"

  # Truncate at word boundary (hyphen) to max 60 chars
  if [[ ${#branch_name} -gt 60 ]]; then
    branch_name="${branch_name:0:60}"
    local truncated="${branch_name%-*}"
    # Guard against empty result if no hyphen in first 60 chars
    branch_name="${truncated:-$branch_name}"
  fi

  hr
  echo ""
  echo "  ${MAGENTA}${ICON_BRANCH}${RESET} ${BOLD}Branch${RESET}"
  echo ""
  echo -n "  ${BOLD}Create a branch for this issue?${RESET} ${DIM}(y/n)${RESET} "
  read -r want_branch
  if [[ "$want_branch" != "y" ]]; then
    echo ""
    return
  fi

  echo ""
  echo -n "  ${BOLD}Branch name${RESET} ${DIM}[${branch_name}]${RESET}: "
  read -r branch_name_input
  branch_name="${branch_name_input:-$branch_name}"

  # Check if branch already exists locally
  if git show-ref --verify --quiet "refs/heads/$branch_name" 2>/dev/null; then
    echo ""
    echo "  ${YELLOW}${ICON_WARN}${RESET} Branch ${BOLD}${branch_name}${RESET} already exists locally."
    echo ""
    echo -n "  ${BOLD}Check out existing branch?${RESET} ${DIM}(y/n)${RESET} "
    read -r do_checkout
    if [[ "$do_checkout" == "y" ]]; then
      checkout_err=$(git checkout "$branch_name" 2>&1) && {
        echo "  ${GREEN}${ICON_OK}${RESET} Switched to ${BOLD}${branch_name}${RESET}"
      } || {
        echo "  ${RED}${ICON_WARN}${RESET} Failed to check out branch"
        echo "  ${DIM}${checkout_err}${RESET}"
      }
    fi
    echo ""
    return
  fi

  # Select base branch — list remote branches sorted by last commit date
  default_branch=$(get_default_branch)

  git fetch origin --quiet 2>/dev/null
  branch_list=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' refs/remotes/origin/ \
    | sed 's|^origin/||' \
    | grep -v '^HEAD$')

  # Move default branch to top of list
  if [[ -n "$default_branch" ]]; then
    branch_list=$(echo "$branch_list" | grep -v "^${default_branch}$")
    branch_list="${default_branch} (default)
${branch_list}"
  fi

  echo ""
  selected_base=$(fzf \
    --prompt="  Base branch > " \
    --header="  ENTER=select  ESC=cancel" \
    --height=~40 \
    --reverse \
    --border=rounded \
    --border-label=" base branch " \
    --color="border:magenta,header:dim,prompt:magenta" \
    <<< "$branch_list" \
    || echo "")

  if [[ -z "$selected_base" ]]; then
    echo "  ${YELLOW}${ICON_WARN}${RESET} Aborted."
    echo ""
    return
  fi

  # Strip "(default)" suffix if present
  selected_base="${selected_base% (default)}"

  branch_err=$(git branch "$branch_name" "origin/$selected_base" 2>&1) && {
    echo ""
    echo "  ${GREEN}${ICON_OK}${RESET} Branch ${BOLD}${branch_name}${RESET} created from ${DIM}${selected_base}${RESET}"

    echo ""
    echo -n "  ${BOLD}Check out branch now?${RESET} ${DIM}(y/n)${RESET} "
    read -r do_checkout

    if [[ "$do_checkout" == "y" ]]; then
      checkout_err=$(git checkout "$branch_name" 2>&1) && {
        echo "  ${GREEN}${ICON_OK}${RESET} Switched to ${BOLD}${branch_name}${RESET}"
      } || {
        echo "  ${RED}${ICON_WARN}${RESET} Failed to check out branch"
        echo "  ${DIM}${checkout_err}${RESET}"
      }
    fi
  } || {
    echo ""
    echo "  ${RED}${ICON_WARN}${RESET} Failed to create branch"
    echo "  ${DIM}${branch_err}${RESET}"
  }

  echo ""
}

# Convert Jira wiki markup to GitLab Markdown
# Uses sed -E (extended regex) with [[:space:]] for macOS BSD sed compatibility
jira_to_markdown() {
  local text="$1"
  # Remove carriage returns
  text=$(tr -d '\r' <<< "$text")
  # Unordered lists: must run BEFORE bold to prevent * item being mangled
  text=$(sed -E 's/^\*\*\*[[:space:]]+/      - /;s/^\*\*[[:space:]]+/    - /;s/^\*[[:space:]]+/- /' <<< "$text")
  # Ordered lists: # item -> 1. item (must run before heading conversion)
  text=$(sed -E 's/^###[[:space:]]+/      1. /;s/^##[[:space:]]+/    1. /;s/^#[[:space:]]+/1. /' <<< "$text")
  # Headings: h1. -> #, h2. -> ##, etc.
  text=$(sed -E 's/^h1\.[[:space:]]*/# /;s/^h2\.[[:space:]]*/## /;s/^h3\.[[:space:]]*/### /;s/^h4\.[[:space:]]*/#### /' <<< "$text")
  # Bold: *text* -> **text** (safe now that bullet * was converted above)
  text=$(sed -E 's/\*([^*]+)\*/**\1**/g' <<< "$text")
  # Italic: _text_ -> *text* (only at word boundaries, not mid-word like my_var_name)
  text=$(sed -E 's/(^|[[:space:]])_([^_]+)_([[:space:],.:;!?)]|$)/\1*\2*\3/g' <<< "$text")
  # Strikethrough: -text- -> ~~text~~ (only at word boundaries)
  text=$(sed -E 's/(^|[[:space:]])-([^- ][^-]*)-([[:space:]]|[,.:;!?)]|$)/\1~~\2~~\3/g' <<< "$text")
  # Links: [text|url] -> [text](url)
  text=$(sed -E 's/\[([^|]*)\|([^]]*)\]/[\1](\2)/g' <<< "$text")
  # Monospace: {{text}} -> `text` (must run BEFORE {code} to avoid {{code}} conflict)
  text=$(sed -E 's/\{\{([^}]*)\}\}/`\1`/g' <<< "$text")
  # Code blocks: {code}...{code} -> ```...```
  text=$(sed -E 's/\{code(:[^}]*)?\}/```/g' <<< "$text")
  # Noformat: {noformat} -> ```
  text=$(sed 's/{noformat}/```/g' <<< "$text")
  # Strip Jira macros: {panel}, {color}, {quote}
  text=$(sed -E 's/\{panel(:[^}]*)?\}//g;s/\{color(:[^}]*)?\}//g;s/\{quote\}//g' <<< "$text")
  # Ensure blank lines between paragraphs for Markdown rendering
  # (Jira single newlines are visible breaks; Markdown needs blank lines)
  # Skips lines inside code blocks to preserve formatting
  text=$(awk '!code && NR>1 && /^./ && prev ~ /^./ {print ""}
             /^```/{code=!code}
             {print; prev=$0}' <<< "$text")
  echo "$text"
}

# Use --clean / -u NONE to prevent custom keymaps (e.g. kj→<Esc>) and plugins
# from interfering with the editing session. noswapfile prevents recovery prompts
# from stale swap files on re-runs.
open_editor() {
  if command -v nvim &>/dev/null; then
    nvim --clean \
      -c "set noswapfile nobackup nowritebackup" \
      -c "syntax on | set filetype=markdown number cursorline" \
      "$1"
  elif command -v vim &>/dev/null; then
    vim -u NONE --noplugin \
      -c "set noswapfile nobackup nowritebackup" \
      -c "syntax on | set filetype=markdown number" \
      "$1"
  elif [[ -n "$VISUAL" ]]; then
    ${=VISUAL} "$1"
  elif [[ -n "$EDITOR" ]]; then
    ${=EDITOR} "$1"
  else
    vi "$1"
  fi
}

# ─── Jira configuration ───
JIRA_PROJECT_PATH="ibm%2Fglab-helper"
JIRA_AVAILABLE=false

load_jira_config() {
  local var_url var_labels var_token

  var_url=$(glab api "projects/${JIRA_PROJECT_PATH}/variables/JIRA_URL" 2>/dev/null)
  if [[ $? -ne 0 ]]; then
    return 1
  fi

  var_labels=$(glab api "projects/${JIRA_PROJECT_PATH}/variables/JIRA_BOARD_LABELS" 2>/dev/null)
  if [[ $? -ne 0 ]]; then
    return 1
  fi

  var_token=$(glab api "projects/${JIRA_PROJECT_PATH}/variables/JIRA_TOKEN" 2>/dev/null)
  if [[ $? -ne 0 ]]; then
    return 1
  fi

  JIRA_URL=$(jq -r '.value' <<< "$var_url")
  JIRA_BOARD_LABELS=$(jq -r '.value' <<< "$var_labels")
  JIRA_TOKEN=$(jq -r '.value' <<< "$var_token")

  if [[ -z "$JIRA_URL" || -z "$JIRA_BOARD_LABELS" || -z "$JIRA_TOKEN" ]]; then
    return 1
  fi

  # Check if current project is the target project
  local var_target
  var_target=$(glab api "projects/${JIRA_PROJECT_PATH}/variables/JIRA_TARGET_PROJECT" 2>/dev/null)
  if [[ $? -ne 0 ]]; then
    return 1
  fi
  JIRA_TARGET_PROJECT=$(jq -r '.value' <<< "$var_target")

  if ! $TESTING && [[ "$repo_name" != "$JIRA_TARGET_PROJECT" ]]; then
    return 1
  fi

  return 0
}

echo -n "  ${DIM}Checking Jira integration...${RESET}"
if load_jira_config; then
  JIRA_AVAILABLE=true
  printf "\r                                      \r"
  echo "  ${GREEN}${ICON_OK}${RESET} ${DIM}Jira integration available${RESET}"
else
  printf "\r                                      \r"
fi
echo ""

# ─── Jira API helpers ───

# Fetch Jira stories that match the board labels
# Sets JIRA_STORIES_JSON (array of issues)
fetch_jira_stories() {
  local labels_jql stories_response

  # Build JQL from comma-separated labels: mind,Core-Service -> labels in (mind,Core-Service)
  labels_jql="labels in (${JIRA_BOARD_LABELS}) AND issuetype = Story"

  stories_response=$(curl -s \
    -H "Authorization: Bearer ${JIRA_TOKEN}" \
    "${JIRA_URL}/rest/api/2/search?jql=$(printf '%s' "$labels_jql" | jq -sRr @uri)&maxResults=100&fields=key,summary,description,status,priority,labels,issuetype,customfield_10000,subtasks")

  if [[ $? -ne 0 ]] || ! jq -e '.issues' <<< "$stories_response" &>/dev/null; then
    return 1
  fi

  JIRA_STORIES_JSON=$(jq '.issues' <<< "$stories_response")
  JIRA_STORIES_COUNT=$(jq 'length' <<< "$JIRA_STORIES_JSON")
  return 0
}

# Fetch Jira epics that match the board labels (with pagination)
# Sets JIRA_EPICS_JSON / JIRA_EPICS_COUNT
fetch_jira_epics() {
  local labels_jql start_at=0 max_results=100 total=-1
  local page_response all_issues="[]"

  labels_jql="labels in (${JIRA_BOARD_LABELS}) AND issuetype = Epic"

  while true; do
    page_response=$(curl -s \
      -H "Authorization: Bearer ${JIRA_TOKEN}" \
      "${JIRA_URL}/rest/api/2/search?jql=$(printf '%s' "$labels_jql" | jq -sRr @uri)&maxResults=${max_results}&startAt=${start_at}&fields=key,summary,status,description")

    if [[ $? -ne 0 ]] || ! jq -e '.issues' <<< "$page_response" &>/dev/null; then
      return 1
    fi

    all_issues=$(jq -s '.[0] + .[1]' <<< "${all_issues}"$'\n'"$(jq '.issues' <<< "$page_response")")
    total=$(jq -r '.total' <<< "$page_response")
    start_at=$((start_at + max_results))

    [[ $start_at -ge $total ]] && break
  done

  JIRA_EPICS_JSON="$all_issues"
  JIRA_EPICS_COUNT=$(jq 'length' <<< "$JIRA_EPICS_JSON")
  return 0
}

